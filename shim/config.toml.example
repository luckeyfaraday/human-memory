# human-memory configuration — copied to ~/.agent-memory/config.toml on install
# (only if one doesn't already exist; your edits are never clobbered on re-install).
# All keys are optional; anything omitted falls back to the built-in default
# shown below. Read by shim/watcher.py.

[watcher]
# How often the watcher scans the working tree for changes, in seconds.
poll_seconds = 5

# Nag once this many file-edits have happened since HUMAN_MEMORY.md last moved.
stale_edit_threshold = 8

# ...or once work has been advancing this long with the whiteboard frozen.
stale_seconds_threshold = 180

# Directory names skipped entirely while scanning (any dotfile dir is also
# skipped automatically). Replaces the default set if specified.
ignore_dirs = [
    ".git", "node_modules", ".venv", "__pycache__", ".context-workspace",
    ".agent-memory", "dist", "build", "target", ".next", ".cache",
]

# File suffixes that don't count as "work" for staleness purposes.
ignore_suffixes = [".pyc", ".log", ".swp", ".tmp"]

[drafter]
# Auto-author HUMAN_MEMORY.md from observed changes. OFF by default: when on, it
# calls a model in the BACKGROUND using your own already-authed agent, which
# spends your tokens and shares your rate limit with the session you're running.
enabled = false

# Cheap/fast model for the summary — the task is "summarize a diff into 5
# sections", which doesn't need a frontier model.
model = "haiku"

# Draft once work has been idle this long (a settled checkpoint), and on exit.
# Not on every edit — that would pay per draft and discard most of them.
quiescence_seconds = 25

# Hard cap on the drafter subprocess; it's killed and we keep the skeleton.
timeout_seconds = 60

# Feed `git diff` as the summarization input when in a git repo.
include_git_diff = true

