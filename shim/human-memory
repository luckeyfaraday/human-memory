#!/usr/bin/env python3
"""human-memory — see what every shimmed agent is doing, at a glance.

The watcher (shim/watcher.py) publishes one JSON status file per live agent
session under $AGENT_MEMORY_HOME/state/. This CLI reads them so staleness
reaches *you* instead of dying in a logfile.

    human-memory            # status table of all live sessions (default)
    human-memory status     # same
    human-memory show [dir] # print the HUMAN_MEMORY.md for dir (default: cwd)
    human-memory nag        # one line iff THIS dir has a stale session (for
                            #   a shell prompt hook); silent otherwise
    human-memory set OWNER  # set OWNER's fenced block in the cwd whiteboard from
                            #   stdin, concurrency-safe (mostly for scripts/tests)

stdlib only. Read-only except `set`, which only ever touches one owner block.
"""

from __future__ import annotations

import importlib.util
import json
import os
import sys
from datetime import datetime, timezone
from pathlib import Path

MEMORY_FILE = "HUMAN_MEMORY.md"


def _load_sibling(module_name: str):
    """Find a sibling module whether running from repo (shim/) or installed
    (bin/ -> ../lib/)."""
    here = Path(__file__).resolve().parent
    filename = f"{module_name}.py"
    for cand in (here / filename, here.parent / "lib" / filename):
        if cand.exists():
            spec = importlib.util.spec_from_file_location(module_name, cand)
            mod = importlib.util.module_from_spec(spec)
            sys.modules[module_name] = mod
            spec.loader.exec_module(mod)
            return mod
    return None


def _load_whiteboard():
    return _load_sibling("whiteboard")


def _load_memory_store():
    return _load_sibling("memory_store")
# A status file whose process is gone but that was never cleaned (e.g. the
# watcher was hard-killed) is considered stale-on-disk after this long.
ORPHAN_SECONDS = 90


def state_dir() -> Path:
    home = os.environ.get("AGENT_MEMORY_HOME") or os.path.join(Path.home(), ".agent-memory")
    return Path(home) / "state"


def pid_alive(pid: int) -> bool:
    """Best-effort liveness, so we don't report a crashed watcher as live."""
    if sys.platform == "win32":
        import ctypes
        from ctypes import wintypes
        k = ctypes.windll.kernel32
        k.OpenProcess.restype = wintypes.HANDLE
        h = k.OpenProcess(0x00100000, False, pid)  # SYNCHRONIZE
        if not h:
            return False
        try:
            return k.WaitForSingleObject(h, 0) == 0x00000102  # WAIT_TIMEOUT
        finally:
            k.CloseHandle(h)
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def _age_seconds(updated: str | None) -> float | None:
    if not updated:
        return None
    try:
        t = datetime.strptime(updated, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
    except ValueError:
        return None
    return (datetime.now(timezone.utc) - t).total_seconds()


def load_sessions(prune: bool = True) -> list[dict]:
    """Read every status file; drop (and optionally delete) dead/orphaned ones."""
    sessions = []
    d = state_dir()
    if not d.exists():
        return sessions
    for f in sorted(d.glob("*.json")):
        try:
            s = json.loads(f.read_text())
        except (OSError, json.JSONDecodeError):
            continue
        age = _age_seconds(s.get("updated"))
        alive = pid_alive(int(s.get("pid", -1)))
        orphaned = (age is not None and age > ORPHAN_SECONDS)
        if not alive or orphaned:
            if prune:
                try:
                    f.unlink()
                except OSError:
                    pass
            continue
        s["_age"] = age
        sessions.append(s)
    return sessions


def _short(path: str, width: int = 40) -> str:
    home = str(Path.home())
    if path.startswith(home):
        path = "~" + path[len(home):]
    return path if len(path) <= width else "…" + path[-(width - 1):]


def cmd_status(_args: list[str]) -> int:
    sessions = load_sessions()
    if not sessions:
        print("No live agent sessions.")
        return 0
    rows = [("AGENT", "PID", "STATE", "BEHIND", "AGE", "DIR")]
    for s in sessions:
        if not s.get("whiteboard_exists"):
            state = "NO FILE"
        elif s.get("stale"):
            state = "STALE"
        else:
            state = "fresh"
        behind = str(s.get("unrecorded_edits", 0))
        age = f"{int(s['_age'])}s" if s.get("_age") is not None else "?"
        rows.append((str(s.get("agent", "?")), str(s.get("pid", "?")), state,
                     behind, age, _short(str(s.get("cwd", "?")))))
    widths = [max(len(r[i]) for r in rows) for i in range(len(rows[0]))]
    for i, r in enumerate(rows):
        line = "  ".join(c.ljust(widths[j]) for j, c in enumerate(r))
        print(line)
    stale = sum(1 for s in sessions if s.get("stale"))
    if stale:
        print(f"\n{stale} session(s) STALE - their human memory is behind the work.")
    return 0


def cmd_show(args: list[str]) -> int:
    ms = _load_memory_store()
    root = Path(args[0]) if args else Path.cwd()
    if ms is None:
        p = root / MEMORY_FILE
    else:
        storage, _note = ms.load_storage()
        p = ms.resolve(root, storage).path
    try:
        sys.stdout.write(p.read_text())
    except OSError:
        print(f"no {MEMORY_FILE} for {root} at {p}", file=sys.stderr)
        return 1
    return 0


def cmd_nag(_args: list[str]) -> int:
    """For a shell prompt hook: one line iff THIS dir has a stale session."""
    cwd = str(Path.cwd())
    stale = [s for s in load_sessions(prune=False)
             if s.get("cwd") == cwd and s.get("stale")]
    if stale:
        worst = max(stale, key=lambda s: s.get("unrecorded_edits", 0))
        print(f"HUMAN_MEMORY.md is stale - {worst.get('unrecorded_edits', 0)} "
              f"edit(s) behind ({worst.get('agent', '?')}). "
              f"`human-memory show` to view.")
    return 0


def cmd_set(args: list[str]) -> int:
    """Set OWNER's block in the cwd whiteboard from stdin (concurrency-safe)."""
    if not args:
        print("usage: human-memory set OWNER  (body on stdin)", file=sys.stderr)
        return 2
    wb = _load_whiteboard()
    if wb is None:
        print("human-memory: whiteboard.py not found", file=sys.stderr)
        return 1
    ms = _load_memory_store()
    body = sys.stdin.read()
    try:
        if ms is None:
            p = Path.cwd() / MEMORY_FILE
        else:
            storage, _note = ms.load_storage()
            location = ms.resolve(Path.cwd(), storage)
            ms.ensure_location(location)
            p = location.path
        wb.update_file(p, args[0], body)
    except (ValueError, TimeoutError, OSError) as e:
        print(f"human-memory: {e}", file=sys.stderr)
        return 1
    return 0


COMMANDS = {"status": cmd_status, "show": cmd_show, "nag": cmd_nag, "set": cmd_set}


def main(argv: list[str]) -> int:
    cmd = argv[0] if argv else "status"
    handler = COMMANDS.get(cmd)
    if handler is None:
        print(f"usage: human-memory [{'|'.join(COMMANDS)}]", file=sys.stderr)
        return 2
    return handler(argv[1:])


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
